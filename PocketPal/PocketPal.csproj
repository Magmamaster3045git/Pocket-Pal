<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <!-- NotifyIcon (system tray) comes from WinForms; this does not turn the app into a WinForms app. -->
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>PocketPal</AssemblyName>
    <RootNamespace>PocketPal</RootNamespace>
    <Platforms>x64</Platforms>
    <StartupObject>PocketPal.App</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\Sprites\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  
    <Content Include="Assets\tray.ico" Condition="Exists('Assets\tray.ico')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
