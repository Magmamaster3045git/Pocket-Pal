<Window x:Class="PocketPal.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PocketPal Settings"
        Width="350"
        Height="300">

    <StackPanel Margin="20">

        <TextBlock Text="Character"
                   FontSize="18"/>

        <ComboBox x:Name="CharacterBox"
                  Margin="0,10">
            <ComboBoxItem>Dog</ComboBoxItem>
            <ComboBoxItem>Cat</ComboBoxItem>
            <ComboBoxItem>Dragon</ComboBoxItem>
        </ComboBox>


        <CheckBox x:Name="StartupBox"
                  Content="Start with Windows"
                  Margin="0,10"/>


        <CheckBox x:Name="ClickThroughBox"
                  Content="Click through character"
                  Margin="0,10"/>


        <CheckBox x:Name="StaticBox"
                  Content="Static mode (don't move)"
                  Margin="0,10"/>


        <Button Content="Save"
                Click="Save_Click"
                Margin="0,20"/>

    </StackPanel>

</Window>
